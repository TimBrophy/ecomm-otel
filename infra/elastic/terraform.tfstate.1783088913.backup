                "config_json": "{\"title\":\"Fraud Detection: Avg Latency by Flag State (ms)\",\"type\":\"data_table\",\"data_source\":{\"type\":\"esql\",\"query\":\"FROM traces-generic.otel-default | WHERE `resource.attributes.service.name` == \\\"checkout-service\\\" AND `span.name` == \\\"POST /checkout\\\" | STATS avg_ms = ROUND(AVG(`duration`) / 1000000, 0) BY flag_state = `attributes.feature_flag.realtime_fraud_detection` | SORT avg_ms DESC\"},\"sampling\":1,\"ignore_global_filters\":false,\"metrics\":[{\"column\":\"avg_ms\"}],\"styling\":{\"density\":{\"mode\":\"default\"}}}",
