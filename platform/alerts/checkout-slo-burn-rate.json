{
  "_meta": {
    "slo_name": "Checkout Service — P99 Latency",
    "note": "sloId is injected at provision time. Window IDs are generated by the provisioning script."
  },
  "name": "Checkout Latency SLO — Fast Burn Rate",
  "rule_type_id": "slo.rules.burnRate",
  "consumer": "slo",
  "schedule": { "interval": "1m" },
  "params": {
    "windows": [
      {
        "burnRateThreshold": 14.4,
        "maxBurnRateThreshold": 720,
        "actionGroup": "slo.burnRate.critical",
        "longWindow": { "value": 1, "unit": "h" },
        "shortWindow": { "value": 5, "unit": "m" }
      },
      {
        "burnRateThreshold": 6,
        "maxBurnRateThreshold": 180,
        "actionGroup": "slo.burnRate.high",
        "longWindow": { "value": 6, "unit": "h" },
        "shortWindow": { "value": 30, "unit": "m" }
      }
    ]
  },
  "actions": [],
  "tags": ["checkout", "slo", "burn-rate", "demo"]
}
