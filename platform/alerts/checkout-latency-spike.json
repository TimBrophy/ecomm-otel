{
  "name": "Checkout — Latency Spike (Incident Alert)",
  "rule_type_id": ".es-query",
  "consumer": "stackAlerts",
  "schedule": { "interval": "1m" },
  "params": {
    "searchType": "esqlQuery",
    "size": 100,
    "esqlQuery": {"esql": "FROM traces-* | WHERE `resource.attributes.service.name` == \"checkout-service\" | STATS p99_ns = PERCENTILE(duration, 99) | WHERE p99_ns > 1000000000"},
    "timeField": "@timestamp",
    "timeWindowSize": 5,
    "timeWindowUnit": "m",
    "threshold": [0],
    "thresholdComparator": ">"
  },
  "actions": [],
  "tags": ["checkout", "latency", "incident", "demo"]
}
