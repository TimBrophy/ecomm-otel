# ── Elastic Cloud ─────────────────────────────────────────────────────────────
# API key from https://cloud.elastic.co/account/keys
export EC_API_KEY=your-ec-api-key

# ── AWS credentials ────────────────────────────────────────────────────────────
export AWS_ACCESS_KEY_ID=your-aws-access-key-id
export AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
export AWS_REGION="eu-central-1"

# ── Terraform state backend ────────────────────────────────────────────────────
export TF_STATE_BUCKET="your-tf-state-bucket-name"

# ── Elastic Cloud project endpoints (populated by ./scripts/demo.sh apply) ────
FLEET_URL=https://YOUR-PROJECT.fleet.eu-central-1.aws.elastic.cloud:443
FLEET_ENROLLMENT_TOKEN=your-fleet-enrollment-token
ELASTICSEARCH_URL=https://YOUR-PROJECT.es.eu-central-1.aws.elastic.cloud
KIBANA_URL=https://YOUR-PROJECT.kb.eu-central-1.aws.elastic.cloud
ELASTIC_INGEST_ENDPOINT=https://YOUR-PROJECT.ingest.eu-central-1.aws.elastic.cloud
ELASTIC_PROJECT_ID=your-elastic-project-id
ELASTIC_INGEST_API_KEY=your-elastic-ingest-api-key

# ── Slack connector (optional — wires alert rules to Slack on apply) ───────────
# SLACK_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL_ID=C0123456789
# SLACK_CHANNEL_NAME=#ecomm-alerts

# ── Universal Profiling EC2 host (optional — used by apply-aws) ───────────────
# ELASTIC_AGENT_VERSION=9.0.1
# KEY_PAIR_NAME=your-ec2-key-pair-name
# SYSTEM_INTEGRATION_VERSION=1.62.0

